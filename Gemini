-- [MODULE 2: TWEEN DI CHUYỂN 3 SEAS]
function TweenTo(TargetCFrame)
    local Character = Player.Character
    if not Character or not Character:FindFirstChild("HumanoidRootPart") then return end
    local Distance = (TargetCFrame.Position - Character.HumanoidRootPart.Position).Magnitude
    local Speed = 350 
    local Info = TweenInfo.new(Distance / Speed, Enum.EasingStyle.Linear)
    local Tween = TweenService:Create(Character.HumanoidRootPart, Info, {CFrame = TargetCFrame})
    Tween:Play()
    
    local NoClipConnection
    NoClipConnection = game:GetService("RunService").Stepped:Connect(function()
        if Tween.PlaybackState == Enum.PlaybackState.Playing then
            for _, part in pairs(Character:GetChildren()) do
                if part:IsA("BasePart") then part.CanCollide = false end
            end
        else
            NoClipConnection:Disconnect()
        end
    end)
    Tween.Completed:Wait()
end

-- [MODULE 3: DỮ LIỆU NHIỆM VỤ CHI TIẾT 3 SEAS]
function GetQuestDetails()
    local Level = Player.Data.Level.Value
    local MySea = game.PlaceId
    if MySea == 2753915541 then -- Sea 1
        if Level >= 1 and Level < 10 then return "BanditQuest1", "Bandit", CFrame.new(1059, 15, 1549), CFrame.new(1145, 17, 1634), 1
        elseif Level >= 10 and Level < 15 then return "MonkeyQuest1", "Monkey", CFrame.new(-1598, 36, 153), CFrame.new(-1610, 37, 146), 1 end
        return "BanditQuest1", "Bandit", CFrame.new(1059, 15, 1549), CFrame.new(1145, 17, 1634), 1
    elseif MySea == 4442272160 then -- Sea 2
        return "Area1Quest", "Raider", CFrame.new(-424, 73, 1836), CFrame.new(-504, 73, 1912), 1
    elseif MySea == 7405815058 then -- Sea 3
        return "PiratePortQuest", "Pirate Millionaire", CFrame.new(-290, 15, 5427), CFrame.new(-340, 15, 5510), 1
    end
end

-- VÒNG LẶP FARM QUÁI
task.spawn(function()
    while true do
        task.wait(0.1)
        if _G.AutoFarm then
            pcall(function()
                local QuestName, MonsterName, NPCCFrame, MonsterCFrame, QuestID = GetQuestDetails()
                local Character = Player.Character
                local HasQuest = string.find(Player.PlayerGui.Main.Quest.Container.QuestTitle.Text, MonsterName)
                
                if not HasQuest then
                    TweenTo(NPCCFrame)
                    task.wait(0.3)
                    ReplicatedStorage.Remotes.CommF_:InvokeServer("StartQuest", QuestName, QuestID)
                else
                    local TargetMonster = nil
                    for _, enemy in pairs(game.Workspace.Enemies:GetChildren()) do
                        if enemy.Name == MonsterName and enemy:FindFirstChild("HumanoidRootPart") and enemy.Humanoid.Health > 0 then
                            TargetMonster = enemy; break
                        end
                    end
                    if TargetMonster then
                        Character.HumanoidRootPart.CFrame = TargetMonster.HumanoidRootPart.CFrame * CFrame.new(0, 11, 0)
                        for _, m in pairs(game.Workspace.Enemies:GetChildren()) do
                            if m.Name == MonsterName and m:FindFirstChild("HumanoidRootPart") then
                                m.HumanoidRootPart.CFrame = TargetMonster.HumanoidRootPart.CFrame
                                m.HumanoidRootPart.CanCollide = false
                            end
                        end
                        local Tool = Player.Backpack:FindFirstChild("Combat") or Character:FindFirstChild("Combat")
                        if Tool then
                            Character.Humanoid:EquipTool(Tool)
                            if _G.FastAttack then
                                ReplicatedStorage.Remotes.Validator:FireServer(math.random(1, 9999))
                                Tool:Activate()
                            end
                        end
                    else
                        TweenTo(MonsterCFrame)
                    end
                end
            end)
        end
    end
end)

